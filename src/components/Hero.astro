---
import { getLang, t } from "../i18n/utils";
const lang = getLang(Astro.currentLocale);
---
<section class="min-h-screen flex flex-col items-center justify-center px-6 pt-16 relative overflow-hidden">
  <div class="text-center max-w-3xl mx-auto">
    <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-gray-900 dark:text-white animate-fade-in-up">
      sugertiger77
    </h1>
    <p class="mt-6 text-lg md:text-xl text-gray-600 dark:text-gray-400 animate-fade-in-up animation-delay-200">
      {t("hero.subtitle", lang)}
    </p>
    <p class="mt-3 text-sm text-gray-500 dark:text-gray-500 animate-fade-in-up animation-delay-300">
      {t("hero.platforms", lang)}
    </p>
    <div class="mt-8 flex items-center justify-center gap-4 animate-fade-in-up animation-delay-400">
      <a
        href="https://github.com/tora-opinion"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-full border border-gray-300 dark:border-gray-700 px-5 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12Z"/></svg>
        {t("hero.github", lang)}
      </a>
    </div>
    <a href="#projects" class="mt-12 inline-block text-sm text-gray-500 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 transition-colors animate-fade-in animation-delay-600">
      {t("hero.viewProjects", lang)}
    </a>
  </div>
</section>
