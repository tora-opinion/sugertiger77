---
import ThemeToggle from "./ThemeToggle.astro";
import LanguageToggle from "./LanguageToggle.astro";
import { getLang, t } from "../i18n/utils";

const lang = getLang(Astro.currentLocale);
---
<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 dark:bg-gray-950/80 backdrop-blur-md border-b border-gray-200/50 dark:border-gray-800/50">
  <nav class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href={lang === "ja" ? "/ja/" : "/"} class="text-lg font-bold tracking-tight text-gray-900 dark:text-gray-100">
      sugertiger77
    </a>
    <div class="flex items-center gap-4">
      <a href="#about" class="hidden sm:block text-sm text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-100 transition-colors">{t("nav.about", lang)}</a>
      <a href="#projects" class="hidden sm:block text-sm text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-100 transition-colors">{t("nav.projects", lang)}</a>
      <a href="#contact" class="hidden sm:block text-sm text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-100 transition-colors">{t("nav.contact", lang)}</a>
      <LanguageToggle />
      <ThemeToggle />
    </div>
  </nav>
</header>
