---
import { projects } from "../i18n/projects";
import ProjectCard from "./ProjectCard.astro";
import { getLang, t } from "../i18n/utils";

const lang = getLang(Astro.currentLocale);
---
<section id="projects" class="py-24 md:py-32 scroll-mt-20">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-gray-900 dark:text-gray-100 animate-on-scroll animate-fade-in-up">
      {t("projects.title", lang)}
    </h2>
    <p class="mt-4 text-base text-gray-600 dark:text-gray-400 animate-on-scroll animate-fade-in-up" style="animation-delay: 0.1s">
      {t("projects.subtitle", lang)}
    </p>
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects[lang].map((project, i) => (
        <div class="animate-on-scroll animate-fade-in-up" style={`animation-delay: ${0.1 + i * 0.15}s`}>
          <ProjectCard project={project} lang={lang} />
        </div>
      ))}
    </div>
  </div>
</section>
